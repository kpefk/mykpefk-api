# ─────────────────────────────────────────────
# Application
# ─────────────────────────────────────────────
NODE_ENV=development                                    # Environment: development | production | test
APPLICATION_PORT=4000                                   # Port on which the application will run
APPLICATION_URL=http://localhost:${APPLICATION_PORT}    # Base URL for the application
ALLOWED_ORIGIN=http://localhost:3000                    # Allowed origin for CORS

# ─────────────────────────────────────────────
# Cookies & Session
# ─────────────────────────────────────────────
COOKIES_SECRET=your_cookies_secret          # Secret key used for signing cookies
SESSION_SECRET=your_session_secret          # Secret key for encrypting sessions
SESSION_NAME=session                        # Session cookie name
SESSION_DOMAIN=localhost                    # Domain for session cookies
SESSION_MAX_AGE=30d                         # Maximum session lifetime (e.g. 30d, 7d, 24h)
SESSION_HTTP_ONLY=true                      # Prevents client-side JS access to cookies
SESSION_SECURE=false                        # Send cookies only over HTTPS (true in production)
SESSION_FOLDER=sessions:                    # Namespace/folder for storing session data in Redis

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=admin                         # PostgreSQL username
POSTGRES_PASSWORD=your_postgres_password    # PostgreSQL password
POSTGRES_HOST=localhost                     # Host where PostgreSQL is running
POSTGRES_PORT=5433                          # Port on which PostgreSQL is running
POSTGRES_DB=your_database_name              # Target database name
POSTGRES_URI=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}  # Full connection URI

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_USER=admin                    # Redis username (if ACL is enabled)
REDIS_PASSWORD=your_redis_password  # Redis password
REDIS_HOST=localhost                # Host where Redis is running
REDIS_PORT=6379                     # Port where Redis is running

# ─────────────────────────────────────────────
# Mail (SMTP)
# ─────────────────────────────────────────────
MAIL_HOST=smtp.gmail.com                # SMTP server host for sending emails
MAIL_PORT=587                           # SMTP port (587 for TLS, 465 for SSL)
MAIL_LOGIN=your_email@example.com       # SMTP login (usually your email address)
MAIL_PASSWORD=your_smtp_app_password    # SMTP app password (not your account password)

# ─────────────────────────────────────────────
# Google reCAPTCHA
# ─────────────────────────────────────────────
GOOGLE_RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key   # Server-side secret key for verifying reCAPTCHA responses

# ─────────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id          # Client ID from Google Cloud Console
GOOGLE_CLIENT_SECRET=your_google_client_secret  # Client Secret from Google Cloud Console

# ─────────────────────────────────────────────
# Google Drive (Service Account)
# ─────────────────────────────────────────────
GOOGLE_DRIVE_CLIENT_EMAIL=your_service_account@project.iam.gserviceaccount.com  # Service account email
GOOGLE_DRIVE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nyour_private_key_here\n-----END PRIVATE KEY-----\n"  # Private key from service account JSON
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id  # Target Google Drive folder ID

# ─────────────────────────────────────────────
# EDBO Integration
# ─────────────────────────────────────────────
EDEBO_CODE=563 
EDBO_BASE_URL=http://localhost:8080/data/EDEBOWebApi  # EDBO REST API base URL (proxy server)
EDBO_APP_KEY=your_edbo_license_key                   # License key for EDBO REST API access
EDBO_USER_LOGIN=your_login@edbo.gov.ua               # EDBO account login
EDBO_USER_PASSWORD=your_edbo_password                # EDBO account password